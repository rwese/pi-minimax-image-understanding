#!/usr/bin/env -S npx -y tsx
/**
 * npm/npx entry point. Thin JS wrapper that runs the TS CLI via the
 * `tsx` runtime, then delegates to src/cli.js (resolved through tsx's
 * loader). Written in plain JS so it parses directly under tsx without
 * any TypeScript-only syntax in the bootstrap path.
 *
 * Unix-only shebang. On Windows, run the equivalent manually:
 *   npx -y tsx node_modules/@rwese/minimax-image-understanding/bin/minimax-image-understanding %*
 */

import { readFileSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { dirname, resolve } from "node:path";

import { run } from "../src/cli.ts";

const here = dirname(fileURLToPath(import.meta.url));
const pkgPath = resolve(here, "..", "package.json");
const pkg = JSON.parse(readFileSync(pkgPath, "utf8"));

run(process.argv.slice(2), {
	stdout: process.stdout,
	stderr: process.stderr,
	version: pkg.version,
}).then(
	(code) => {
		process.exit(code);
	},
	(err) => {
		process.stderr.write("unexpected error: " + ((err && err.stack) || String(err)) + "\n");
		process.exit(1);
	},
);